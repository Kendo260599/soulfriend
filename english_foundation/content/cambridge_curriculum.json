{
  "framework": "IELTS-aligned Grammar and Vocabulary path for Vietnamese learners",
  "exam_alignment": {
    "primary": "IELTS Academic and IELTS General Training",
    "band_focus": "Grammar and Vocabulary foundation for IELTS band 4.0 to 6.0",
    "design_note": "Beginner-safe progression using CEFR order (A1-A2-B1) mapped to IELTS language needs."
  },
  "scope": {
    "enabled_tracks": ["grammar", "vocab"],
    "disabled": ["listening", "reading", "writing", "speaking"]
  },
