    "grammar": [
      {
        "id": "GR-A1-01",
        "order": 1,
        "level": "A1",
        "title": "Be Verb and Subject",
        "focus": "I am / You are / He is",
        "objective": "Build basic identity statements."
      },
      {
        "id": "GR-A1-02",
        "order": 2,
        "level": "A1",
        "title": "Present Simple Statements",
        "focus": "I work / He works",
        "objective": "Make basic present simple sentences."
      },
      {
        "id": "GR-A1-03",
        "order": 3,
        "level": "A1",
        "title": "Present Simple Questions",
        "focus": "Do you work? / Does he work?",
        "objective": "Ask and answer basic routine questions."
      },
      {
        "id": "GR-A1-04",
        "order": 4,
        "level": "A1",
        "title": "There is / There are",
        "focus": "There is a table.",
        "objective": "Describe simple place and objects."
      },
      {
        "id": "GR-A1-05",
        "order": 5,
        "level": "A1",
        "title": "Can / Cannot",
        "focus": "I can swim. / I cannot drive.",
        "objective": "Talk about ability in short sentences."
      },
      {
        "id": "GR-A1-06",
        "order": 6,
        "level": "A1",
        "title": "Present Continuous Basics",
        "focus": "I am working now.",
        "objective": "Describe action happening now."
      },
      {
        "id": "GR-A1-07",
        "order": 7,
        "level": "A1",
        "title": "Countable and Uncountable",
        "focus": "some / any",
        "objective": "Talk about quantity in daily contexts."
      },
      {
        "id": "GR-A1-08",
        "order": 8,
        "level": "A1",
        "title": "Past Simple Intro",
        "focus": "I worked yesterday.",
        "objective": "Describe one simple past event."
      },
      {
        "id": "GR-A2-01",
        "order": 9,
        "level": "A2",
        "title": "Past Simple Irregular",
        "focus": "go-went, have-had, get-got",
        "objective": "Use common irregular verbs in past simple."
      },
      {
        "id": "GR-A2-02",
        "order": 10,
        "level": "A2",
        "title": "Future Plan with Going to",
        "focus": "I am going to study tonight.",
        "objective": "Talk about short-term plans."
      },
      {
        "id": "GR-A2-03",
        "order": 11,
        "level": "A2",
        "title": "Will for Offer and Prediction",
        "focus": "I will help you.",
        "objective": "Use will in simple practical contexts."
      },
      {
        "id": "GR-A2-04",
        "order": 12,
        "level": "A2",
        "title": "Comparative and Superlative",
        "focus": "bigger, the biggest",
        "objective": "Compare people and things simply."
      },
      {
        "id": "GR-A2-05",
        "order": 13,
        "level": "A2",
        "title": "Present Perfect Intro",
        "focus": "I have finished.",
        "objective": "Connect past action to present result."
      },
      {
        "id": "GR-A2-06",
        "order": 14,
        "level": "A2",
        "title": "Must, Have to, Should",
        "focus": "You should rest.",
        "objective": "Give basic advice and obligation."
      },
      {
        "id": "GR-A2-07",
        "order": 15,
        "level": "A2",
        "title": "First Conditional",
        "focus": "If it rains, I will stay home.",
        "objective": "Talk about possible future results."
      },
      {
        "id": "GR-A2-08",
        "order": 16,
        "level": "A2",
        "title": "Gerund and Infinitive Basics",
        "focus": "like reading / want to learn",
        "objective": "Use common verb patterns correctly."
      },
      {
        "id": "GR-B1-01",
        "order": 17,
        "level": "B1",
        "title": "Present Perfect vs Past Simple",
        "focus": "I have lived / I lived",
        "objective": "Choose tense by time meaning."
      },
      {
        "id": "GR-B1-02",
        "order": 18,
        "level": "B1",
        "title": "Present Perfect with For/Since",
        "focus": "for two years / since 2022",
        "objective": "Describe duration clearly."
      },
      {
        "id": "GR-B1-03",
        "order": 19,
        "level": "B1",
        "title": "Second Conditional",
        "focus": "If I had time, I would study more.",
        "objective": "Talk about unreal present situations."
      },
      {
        "id": "GR-B1-04",
        "order": 20,
        "level": "B1",
        "title": "Passive Voice Basics",
        "focus": "The task was finished.",
        "objective": "Use passive in common reports."
      },
      {
        "id": "GR-B1-05",
        "order": 21,
        "level": "B1",
        "title": "Relative Clauses",
        "focus": "who, which, that",
        "objective": "Add clear extra information to nouns."
      },
      {
        "id": "GR-B1-06",
        "order": 22,
        "level": "B1",
        "title": "Reported Speech",
        "focus": "He said that he was tired.",
        "objective": "Report statements and simple questions."
      },
      {
        "id": "GR-B1-07",
        "order": 23,
        "level": "B1",
        "title": "Modals of Deduction",
        "focus": "must, might, cannot",
        "objective": "Express certainty and possibility."
      },
      {
        "id": "GR-B1-08",
        "order": 24,
        "level": "B1",
        "title": "Linking and Clause Building",
        "focus": "although, because, so, however",
        "objective": "Build longer clear B1-level sentences."
      }
